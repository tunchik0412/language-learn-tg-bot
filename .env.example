# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/language_learn_bot?schema=public"

# Redis Configuration (optional, for caching)
REDIS_URL="redis://localhost:6379"
REDIS_ENABLED=false

# Encryption Key (generate a secure 32-character key)
ENCRYPTION_KEY=your_32_character_encryption_key_

# Default AI Provider (gemini, openai, claude)
DEFAULT_AI_PROVIDER=gemini

# AI Provider API Keys (optional fallbacks if user doesn't provide their own)
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Bot Settings
BOT_WEBHOOK_DOMAIN=
BOT_WEBHOOK_PORT=3000
USE_WEBHOOK=false

# Environment
NODE_ENV=development
